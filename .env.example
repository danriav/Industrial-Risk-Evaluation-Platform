# MERO - ejemplo de variables de entorno.
# Copiar a .env y reemplazar todos los valores CHANGE_ME antes de iniciar.

COMPOSE_PROJECT_NAME=mero

# Puertos autorizados por el cliente
FRONTEND_PORT=3000
BACKEND_PORT=8080
POSTGRES_PORT=5432
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Imagenes de aplicacion precompiladas
FRONTEND_IMAGE=mero-frontend:local
BACKEND_IMAGE=mero-backend:local
API_BASE_URL=http://localhost:8080
VITE_API_BASE_URL=http://localhost:8080

# API Core
BASIC_AUTH_USERNAME=mero_admin
BASIC_AUTH_PASSWORD=CHANGE_ME_STRONG_BASIC_AUTH_PASSWORD
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FORCE_HTTPS=false
MODEL_PATH=artifacts/models/random_forest.joblib

# PostgreSQL
POSTGRES_VERSION=16-alpine
POSTGRES_DB=mero
POSTGRES_USER=mero_app
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
DATABASE_URL=postgresql+psycopg://mero_app:CHANGE_ME_STRONG_DATABASE_PASSWORD@127.0.0.1:5432/mero

# Respaldos
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14
BACKUP_RETRY_SECONDS=10
BACKUP_MAX_ATTEMPTS=12

# Observabilidad
PROMETHEUS_VERSION=v2.53.0
PROMETHEUS_RETENTION=15d
POSTGRES_EXPORTER_VERSION=v0.15.0
GRAFANA_VERSION=11.1.0
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_GRAFANA_PASSWORD
